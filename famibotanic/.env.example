# Base de données PostgreSQL (fournie automatiquement par Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/fichelab

# Clé API Anthropic — à créer sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modèle utilisé pour la génération (optionnel)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Mot de passe d'accès à l'app (optionnel mais recommandé pour un outil interne)
# Si défini, une authentification s'affichera (utilisateur : ce que vous voulez, mot de passe : cette valeur)
APP_PASSWORD=

# Mettre à "true" si la connexion PostgreSQL exige SSL (connexion externe à Railway)
DATABASE_SSL=false

# Schéma PostgreSQL dédié à l'app — utile si plusieurs apps partagent la même base
# (chaque app garde ses tables isolées dans son propre schéma). Défaut : public
DATABASE_SCHEMA=famibotanic

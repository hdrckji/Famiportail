# Connexion MySQL (format mysql://user:pass@host:port/base).
# Sur Railway : referencer MYSQL_URL du service MySQL.
DATABASE_URL=mysql://user:password@localhost:3306/famibotanic

# Cle API Anthropic (obligatoire pour la generation IA).
ANTHROPIC_API_KEY=

# Modele IA (facultatif, defaut : claude-sonnet-4-6).
ANTHROPIC_MODEL=

# Prefixe des tables de l'app (facultatif, defaut : famibotanic_).
DB_PREFIX=

# Mot de passe de l'app (facultatif ; si defini, l'app est protegee).
APP_PASSWORD=

# SSL MySQL (facultatif ; "true" seulement pour une connexion externe a Railway).
DATABASE_SSL=
